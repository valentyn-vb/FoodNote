# Backend
PORT=3001

# Auth (JWT) — override the dev defaults in any real deployment
JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://foodnote:foodnote@localhost:5432/foodnote

# Frontend dev server — where the Next.js proxy forwards /api/* requests
API_URL=http://localhost:3001
